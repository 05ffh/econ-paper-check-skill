__pycache__/
*.pyc
*.pyo
.pytest_cache/
.DS_Store
*.egg-info/

# 运行时工作目录（不入库）
.econ-paper-check/

# 临时构建产物
*.tmp

# M1 知识库私有治理（补齐清单 P0-4 + 授权治理要求）
.private/
knowledge_base/vector_db/active/
knowledge_base/vector_db/snapshots/
knowledge_base/logs/
knowledge_base/examples/parsed/
knowledge_base/.private/

# M3 视觉模块（Phase 1+）
.env
.env.local
.env.*.local
.cache/
.cache/vision/
*.bundle
tests/vision/fixtures/authorized_real_pages/*
!tests/vision/fixtures/authorized_real_pages/.gitkeep
tests/vision/fixtures/synthetic_tables/*.png
tests/vision/fixtures/synthetic_tables/*.jpg
tests/vision/fixtures/adversarial/*.png
tests/vision/fixtures/adversarial/*.jpg
# 保留 fixture 元数据（yaml/json）
!tests/vision/fixtures/**/*.yaml
!tests/vision/fixtures/**/*.json

# Python 3.11 lock（Docker 生成）
!constraints-py311.txt

# Debug 视觉临时文件
.debug_vision/

# Local Python virtualenvs (M3 v1.6+)
.venv/
.venv-*/
venv/
env/
.workdir/

# ==== M4 Benchmark ====
# 私有真实论文原始文件不入 Git（Sample Governance §六）
benchmarks/documents/private_local_manifest/*/source/
benchmarks/documents/private_local_manifest/*/canonical_result.json
# 候选运行的 artifacts full 目录可能含正文回读
benchmarks/runs/*/artifacts/full/
# 授权文档留本地，不入 Git
docs/consent/*.consent.md
# 环境锁（每台机器不同）不进版本控制；但 dependency_lock_hash 会被记录到 metrics
benchmarks/env/lock.txt

