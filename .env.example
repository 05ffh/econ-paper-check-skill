# 经管论文智检 Skill · .env.example
# 复制为 .env 后修改。.env 已在 .gitignore 中，不会入 Git。
#
# ⚠️ 严禁在本文件中填写真实 API Key
# ⚠️ 部署者按需修改；未修改也能以 Core 模式运行

# =========================
# 运行模式
# =========================
# 可选值：core | local_vision | cloud_enhanced | auto
# 默认：core（零 Key 可跑，视觉全关）
RUNTIME_MODE=core

# =========================
# 视觉模块总开关
# =========================
VISION_ENABLED=false
VISION_PROVIDER=none
VISION_FALLBACK_PROVIDER=none

# =========================
# 火山方舟多模态 Provider（Cloud Enhanced）
# =========================
# 部署者从火山方舟控制台复制以下三项；不配置则 Cloud Enhanced 不可用
ARK_API_KEY=
ARK_BASE_URL=
# ⚠️ 具体模型 endpoint id 由部署者按 benchmark 结果配置，通用 Skill 源码不写死
ARK_VISION_MODEL_ID=
ARK_REGION=

# =========================
# 第二云 Provider（默认关闭）
# =========================
# 只有当"用户授权 + benchmark 证明有价值 + 冲突场景 + 预算允许"四条件满足才开启
SECONDARY_VISION_ENABLED=false
SECONDARY_API_KEY=
SECONDARY_BASE_URL=
SECONDARY_MODEL_ID=

# =========================
# Local Vision（PaddleOCR）
# =========================
LOCAL_VISION_ENABLED=false
LOCAL_OCR_ENGINE=paddleocr
LOCAL_MODEL_PATH=
LOCAL_DEVICE=cpu

# =========================
# 预算与限流
# =========================
MAX_CLOUD_COST_CNY_PER_DOCUMENT=3.0
MAX_CLOUD_REGIONS_PER_DOCUMENT=30
MAX_SECONDARY_MODEL_CALLS=5
MAX_RETRIES_PER_REGION=2
MAX_PROCESSING_SECONDS=300

# =========================
# 隐私授权
# =========================
# 部署者技术门禁；同时还需要用户会话第一次云端调用前显式同意
ALLOW_CLOUD_UPLOAD=false
# 整页上传需要独立授权 + 用户再次确认
ALLOW_FULL_PAGE_UPLOAD=false
# 海外 Provider：M3 未实现，配置保留供 M4+ 使用
ALLOW_OVERSEAS_PROVIDER=false

# =========================
# 临时文件生命周期
# =========================
DELETE_TEMP_VISUAL_FILES=true
# 正常模式：0（响应后立即删除）
# Debug 模式：≤ 24
VISUAL_ARTIFACT_RETENTION_HOURS=0

# =========================
# Debug 模式（谨慎开启）
# =========================
# 开启后 raw_response_ref 会临时落盘，24h 内自动清理
DEBUG_KEEP_RAW_RESPONSE=false
DEBUG_RAW_RESPONSE_RETENTION_HOURS=24

# =========================
# 缓存
# =========================
VISION_CACHE_RETENTION_DAYS=7

# =========================
# 日志
# =========================
LOG_LEVEL=INFO
LOG_FULL_MODEL_RESPONSE=false
LOG_FULL_IMAGE_PATH=false
