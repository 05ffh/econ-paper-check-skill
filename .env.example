# 经管论文智检 Skill · .env.example
# v0.3.1 轻量化 · 6 个变量 · 复制为 .env 后修改
#
# ⚠️ 严禁在本文件中填写真实 API Key
# ⚠️ 未修改也能以基础质检模式运行（DOCX/文本 PDF/KB-A 全可用）

# =========================
# 视觉辅助识别（可选）
# =========================
# 三合一启用条件：VISION_ENABLED + ARK_API_KEY + ARK_VISION_MODEL_ID
# 任一缺失 → 图片内容降灰 · 不影响基础质检
VISION_ENABLED=false

# 火山方舟 · OpenAI Compatible 接口（不绑豆包，模型 ID 由部署者配）
ARK_API_KEY=
ARK_VISION_MODEL_ID=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# =========================
# 调用保护（v0.3.1 P0-7）
# =========================
# 单篇论文最多调用视觉识别次数（避免恶意 PDF 打爆预算）
MAX_VISION_REGIONS_PER_DOCUMENT=40
# 单次 Ark 调用超时（秒）
VISION_REQUEST_TIMEOUT_SECONDS=30

# =========================
# 日志（可选）
# =========================
LOG_LEVEL=INFO
